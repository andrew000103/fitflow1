EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# 식품의약품안전처 식품영양성분 DB API 키
EXPO_PUBLIC_MFDS_API_KEY=

# USDA FoodData Central API 키

# 운동 종목 콘텐츠 자동 수집 스크립트용 환경 변수
# 이 파일을 복사해서 .env.scripts 로 이름을 바꾸고 실제 값을 채우세요.
# .env.scripts 는 .gitignore 에 의해 커밋에서 제외됩니다.

# Supabase (필수)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# YouTube Data API v3 (선택 — visual_guide_url GIF 미수집 시 YouTube 폴백)
# https://console.cloud.google.com 에서 발급
YOUTUBE_API_KEY=your-youtube-api-key-here

# GIPHY API (선택 — visual_guide_url GIF 우선 수집)
# https://developers.giphy.com 에서 발급
GIPHY_API_KEY=your-giphy-api-key-here
